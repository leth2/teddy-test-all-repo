FROM node:20-alpine

WORKDIR /app

# Lesson D01: npm ci вҶ’ build вҶ’ prune (tscк°Җ devDependenciesм—җ мһҲмңјлҜҖлЎң build лЁјм Җ)
COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/

RUN npm run build
RUN npm prune --omit=dev

# Cline CLI м „м—ӯ м„Өм№ҳ
RUN npm install -g cline

EXPOSE 3002

CMD ["node", "dist/index.js"]
