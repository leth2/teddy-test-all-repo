{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDD Test Results",
  "description": "Quinn이 test-queue 실행 후 저장하는 결과 포맷 v1.0",
  "type": "object",
  "required": ["queue_id", "run_at", "passed", "failed", "skipped", "tasks"],
  "properties": {
    "queue_id": {
      "type": "string",
      "description": "실행한 test-queue 파일명"
    },
    "spec_id": {
      "type": "string",
      "description": "연결된 SDD 스펙 폴더명"
    },
    "run_at": {
      "type": "string",
      "format": "date-time",
      "description": "테스트 실행 시작 시각 (UTC)"
    },
    "duration_ms": {
      "type": "integer",
      "description": "전체 실행 소요 시간 (ms)"
    },
    "passed": { "type": "integer" },
    "failed": { "type": "integer" },
    "skipped": {
      "type": "integer",
      "description": "depends_on 실패로 건너뛴 태스크 수"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skip", "timeout"]
          },
          "duration_ms": {
            "type": "integer",
            "description": "개별 태스크 소요 시간"
          },
          "reason": {
            "type": "string",
            "description": "실패/스킵 이유 (fail/skip/timeout 시)"
          },
          "output": {
            "type": "string",
            "description": "실제 출력값 또는 에러 메시지"
          },
          "retries": {
            "type": "integer",
            "description": "재시도 횟수"
          }
        }
      }
    },
    "escalated": {
      "type": "array",
      "items": { "type": "string" },
      "description": "on_failure=escalate 태스크 ID 목록 — Finn에게 알림 필요"
    }
  }
}
